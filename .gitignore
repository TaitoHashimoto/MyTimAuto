# ==========================================================
# 個人情報・認証情報を含むファイル（絶対にコミット禁止）
# ==========================================================

# ユーザー固有設定（個人情報・組織情報を含む）
config.py

# Edge永続セッション（Cookie / プロファイル）
session/

# 認証Cookie（Playwright storage_state）
storage.json

# 実行時の状態
overtime_state.json

# タスクスケジューラ設定（フルパス含む。テンプレートは overtime_task.example.xml）
overtime_task.xml

# 全てのログファイル（業務内容・氏名・メールアドレスを含む）
*.log

# 全てのスクリーンショット（Teamsチャット内容・MyTim画面を含む）
*.png
*.jpg
*.jpeg

# デバッグダンプ
teams_debug.txt
*_debug.txt

# ==========================================================
# Python 標準
# ==========================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ==========================================================
# OS / エディタ
# ==========================================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
